<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashboardMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fintech_background"
    tools:context=".DashboardActivity">

    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/fintech_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Hola, Wilson!"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAccountDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CVU: 0000003100012345678901"
            android:textColor="@color/fintech_background"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llBalanceCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saldo disponible en cuenta"
            android:textColor="@color/text_dark"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTotalBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ 450.500,00"
            android:textColor="@color/fintech_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="16dp"
            android:layout_bottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Inversiones (CEDEARs)"
                    android:textSize="12sp"
                    android:textColor="#757575"/>
                <TextView
                    android:id="@+id/tvInvestments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$ 120.000,00"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/success_green"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dólar MEP equiv."
                    android:textSize="12sp"
                    android:textColor="#757575"/>
                <TextView
                    android:id="@+id/tvDollarBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="u$s 345,00"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/fintech_secondary"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvActionsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Operaciones disponibles"
        android:textColor="@color/text_dark"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/llBalanceCard"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnGoToTransfer"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Enviar Dinero (Transferir)"
        android:textColor="@color/white"
        android:backgroundTint="@color/fintech_primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvActionsTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>